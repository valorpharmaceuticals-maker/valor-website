# Base URL of the existing ERP backend (backend-pharma-fastify) that will
# expose the public Website CMS endpoints. When the CMS is wired, the site
# fetches its content from here. Until then everything comes from src/data.
# ERP backend base URL (serves the public website content at /public/site).
# Local: the ERP backend defaults to port 4001 (see backend-pharma-fastify/src/main.ts)
# Production: your deployed Railway URL, e.g. https://your-app.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001

# Public URL where THIS website is deployed. Used for canonical URLs,
# sitemap.xml, robots.txt and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://example.com
